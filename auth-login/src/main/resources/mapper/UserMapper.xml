<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.keli.authlogin.mapper.UserMapper">

    <resultMap id="userWithRolesMap" type="com.keli.authlogin.entity.User">
        <!-- 用户主键 -->
        <id column="id" property="id"/>
        <result column="uid" property="uid"/>
        <!-- 用户其他字段 -->
        <result column="username" property="username"/>
        <result column="phone" property="phone"/>
        <result column="email" property="email"/>
        <result column="password" property="password"/>
        <result column="status" property="status"/>
        <result column="last_login_ip" property="lastLoginIp"/>
        <result column="last_login_time" property="lastLoginTime"/>
        <result column="created_at" property="createdAt"/>
        <result column="updated_at" property="updatedAt"/>
        <!-- 角色集合映射 -->
        <collection property="roles" ofType="com.keli.authlogin.entity.Role">
            <id column="role_id" property="id"/>
            <result column="role_code" property="code"/>
            <result column="role_name" property="name"/>
            <result column="role_description" property="description"/>
        </collection>
    </resultMap>

    <select id="selectUserWithRolesByUsername" resultMap="userWithRolesMap">
        SELECT
            u.*,
            r.id AS role_id,
            r.code AS role_code,
            r.name AS role_name,
            r.description AS role_description
        FROM `user` u
                 LEFT JOIN user_role ur ON u.id = ur.user_id
                 LEFT JOIN role r ON ur.role_id = r.id
        WHERE u.username = #{username}
    </select>
    <select id="selectUserWithRolesByPhone" resultMap="userWithRolesMap">
        SELECT
            u.*,
            r.id AS role_id,
            r.code AS role_code,
            r.name AS role_name,
            r.description AS role_description
        FROM `user` u
                 LEFT JOIN user_role ur ON u.id = ur.user_id
                 LEFT JOIN role r ON ur.role_id = r.id
        WHERE u.phone = #{phoneNumber}
    </select>
    <select id="selectUserWithRolesByEmail" resultMap="userWithRolesMap">
        SELECT
            u.*,
            r.id AS role_id,
            r.code AS role_code,
            r.name AS role_name,
            r.description AS role_description
        FROM `user` u
                 LEFT JOIN user_role ur ON u.id = ur.user_id
                 LEFT JOIN role r ON ur.role_id = r.id
        WHERE u.email = #{email}
    </select>
</mapper>